{
  "manifest_version": 3,
  "name": "Table Export Extension",
  "version": "1.0",
  "description": "Export tables in XLS, DOC",
  "permissions": [
    "scripting",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/tableParser.js","js/tableDetector.js", "js/excelExporter.js", "js/docExporter.js", "js/exportButton.js", "js/contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}